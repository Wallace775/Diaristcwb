{
  "expo": {
    "name": "DiaristCWB",
    "slug": "Diaristcwb",
    "scheme": "diaristcwb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.wallacephellipe.diaristcwb",
      "versionCode": 1,
      "config": {
        "googleMaps": {
          "apiKey": "$EXPO_PUBLIC_GOOGLE_MAPS_API_KEY"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121212"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "O DiaristCWB precisa acessar sua galeria para usar sua foto de perfil.",
          "cameraPermission": "O DiaristCWB precisa acessar sua câmera para tirar uma foto de perfil."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permitir que o DiaristCWB acesse sua localização para encontrar diaristas próximas."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "16676463-edb5-4423-b8aa-ec254d6d7fae"
      }
    }
  }
}